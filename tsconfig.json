{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node"
  },
  "include": ["src/backend/**/*", "src/config/**/*", "src/db/**/*", "src/gmail/**/*", "src/parser/**/*", "src/ai/**/*", "src/sender/**/*", "src/utils/**/*"],
  "exclude": ["node_modules", "dist", "frontend-dist", "src/frontend/**/*"]
}
